# Graphene Intel — Environment Variables Template
# Copy to .env and fill in your values

# === Claude API ===
ANTHROPIC_API_KEY=sk-ant-...

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=123456789:AAxxxxx...
TELEGRAM_CHAT_ID=-100xxxxxxxxxx    # Use negative for group chats

# === Reddit API (optional, for sentiment) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=graphene-intel/0.1 by u/yourname

# === Database ===
DB_PATH=/opt/grafene/data/graphene.db

# === Logging ===
LOG_LEVEL=INFO
LOG_DIR=/var/log/graphene-intel

# === Scoring threshold ===
ALERT_THRESHOLD=7
